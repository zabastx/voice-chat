# Public domain for this relay (used by the bundled Caddy for auto-HTTPS).
# Its A/AAAA record must point at this host, with ports 80/443 open.
RELAY_DOMAIN=relay.example.com

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# This relay's own public HTTPS webhook URL (Telegram POSTs updates here).
# With the bundled Caddy this is https://${RELAY_DOMAIN}/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://relay.example.com/telegram/webhook
# random 32+ char string; Telegram echoes it in X-Telegram-Bot-Api-Secret-Header
TELEGRAM_WEBHOOK_SECRET=

# Main voice-chat app ingest endpoint
INGEST_URL=https://chat.example.com/api/telegram/ingest
# shared bearer secret; MUST equal the main app's NUXT_TELEGRAM_RELAY_SECRET
RELAY_SECRET=

# port the relay listens on (Nitro/nitro output honors PORT)
PORT=3000
