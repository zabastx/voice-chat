# ===== Domain =====
# DNS A records required for BOTH:  {DOMAIN}  and  livekit.{DOMAIN}  -> VPS IP
DOMAIN=chat.example.com

# ===== Sessions =====
# random string, 32+ characters:  openssl rand -hex 32
NUXT_SESSION_PASSWORD=

# ===== LiveKit =====
# key name must stay "voicechat" (referenced in deploy/livekit.yaml webhook config)
NUXT_LIVEKIT_API_KEY=voicechat
# random secret, 32+ characters:  openssl rand -hex 32
NUXT_LIVEKIT_API_SECRET=
# public signaling URL for browsers (subdomain from above, wss://)
NUXT_PUBLIC_LIVEKIT_URL=wss://livekit.chat.example.com

# ===== S3-compatible storage (attachments) =====
# from your hosting provider's object storage page (S3 credentials, not Swift)
NUXT_S3_ENDPOINT=https://s3.example-provider.com
NUXT_S3_BUCKET=
NUXT_S3_REGION=ru-1
NUXT_S3_ACCESS_KEY_ID=
NUXT_S3_SECRET_ACCESS_KEY=

# ===== Local dev only (compose.dev.yaml) =====
# Your machine's LAN IP, used as LiveKit's --node-ip. Firefox blocks TURN
# allocations to 127.0.0.1, so for voice in Firefox set this to a non-loopback
# IP (Chrome works without it). Not used in production.
LIVEKIT_NODE_IP=
